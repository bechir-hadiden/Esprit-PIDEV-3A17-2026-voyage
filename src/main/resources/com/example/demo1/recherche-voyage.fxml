<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1">

    <!-- 🔍 Zone de recherche -->
    <TitledPane text="Recherche de voyages" expanded="true">
        <content>
            <GridPane hgap="10" vgap="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Label text="Destination :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tfRechercheDestination"
                           promptText="Ex : Paris"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Date départ :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dpDateDepart"
                            GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Prix max :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="tfPrixMax"
                           promptText="Ex : 1500"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button text="Rechercher"
                        GridPane.rowIndex="3"
                        GridPane.columnIndex="1"
                        prefWidth="120"/>
            </GridPane>
        </content>
    </TitledPane>

    <!-- 📋 Résultats -->
    <TableView fx:id="tableVoyages" prefHeight="300">

        <columns>
            <TableColumn fx:id="colDestination" text="Destination" prefWidth="150"/>
            <TableColumn fx:id="colDateDepart" text="Date départ" prefWidth="120"/>
            <TableColumn fx:id="colDuree" text="Durée" prefWidth="80"/>
            <TableColumn fx:id="colPrix" text="Prix" prefWidth="100"/>
        </columns>

    </TableView>

</VBox>
