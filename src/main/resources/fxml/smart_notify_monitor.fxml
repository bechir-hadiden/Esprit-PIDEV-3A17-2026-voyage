<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.SmartNotifyMonitorController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <stylesheets>
        <URL value="@../css/style.css" />
        <URL value="@../css/admin-styles.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 30 40 10 40;">
        <Button text="← Retour" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <Label text="SmartNotify Monitoring" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
        </VBox>
        <Button text="🔄  Rafraîchir" onAction="#loadNotifications" styleClass="admin-button-primary" style="-fx-padding: 8 16;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="24" style="-fx-padding: 30 36;" alignment="TOP_CENTER">

            <VBox spacing="8" alignment="CENTER_LEFT" maxWidth="1000">
                <Label text="Alertes d'Annulation" styleClass="stats-section-title" style="-fx-font-size: 22px;"/>
                <Label text="Historique des réservations annulées par les utilisateurs" styleClass="stats-section-sub"/>
            </VBox>
            
            <VBox styleClass="admin-card" spacing="0" VBox.vgrow="ALWAYS" maxWidth="1000">
                <TableView fx:id="notificationTable" VBox.vgrow="ALWAYS" styleClass="admin-table" prefHeight="500">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colDate" text="Date de l'alerte" prefWidth="180"/>
                        <TableColumn fx:id="colMessage" text="Message" prefWidth="480"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="140" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune alerte pour le moment." styleClass="stats-section-sub"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>

