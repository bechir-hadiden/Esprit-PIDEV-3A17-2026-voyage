<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo1.controller.DestinationController"
      spacing="0"
      stylesheets="@../css/smarttrip_theme.css"
      style="-fx-background-color: #f5f0e8;">

    <!-- ===== HEADER ===== -->
    <HBox style="-fx-background-color: #0d1b2a; -fx-padding: 24;"
          alignment="CENTER_LEFT" spacing="15">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="🌍 Destinations"
                   style="-fx-font-family: 'Playfair Display'; -fx-font-size: 28px; -fx-font-weight: bold;
                          -fx-text-fill: #c9a84c;"/>
            <Label fx:id="lblCount"
                   text="0 destinations"
                   style="-fx-font-family: 'Plus Jakarta Sans', sans-serif; -fx-font-size: 13px;
                          -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
        <Button text="➕ Ajouter"
                onAction="#handleAjouter"
                styleClass="btn-primary"
                style="-fx-padding: 10 24;"/>
    </HBox>

    <!-- ===== BARRE DE RECHERCHE ===== -->
    <HBox style="-fx-background-color: white; -fx-padding: 18;
                 -fx-border-color: rgba(201,168,76,0.2); -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="12">
        <TextField fx:id="tfRecherche"
                   promptText="🔍 Rechercher une destination..."
                   prefWidth="320"
                   onKeyReleased="#handleRecherche"
                   styleClass="form-input-light"
                   style="-fx-padding: 10 15;"/>
        <Button text="🔄 Actualiser"
                onAction="#handleActualiser"
                styleClass="btn-outline-light"
                style="-fx-border-color: #0d1b2a; -fx-text-fill: #0d1b2a; -fx-padding: 10 20;"/>
    </HBox>

    <!-- ===== GRILLE DES DESTINATIONS ===== -->
    <ScrollPane fitToWidth="true"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-background: transparent; -fx-border-color: transparent;">
        <GridPane fx:id="gridDestinations"
                  hgap="24" vgap="24"
                  style="-fx-padding: 30;
                         -fx-background-color: #f5f0e8;"/>
    </ScrollPane>

    <!-- ===== LOADING ===== -->
    <HBox fx:id="hboxLoading"
          alignment="CENTER"
          spacing="10"
          style="-fx-padding: 20;"
          visible="false">
        <ProgressIndicator prefWidth="30" prefHeight="30"/>
        <Label text="Chargement..."
               style="-fx-font-family: 'Plus Jakarta Sans', sans-serif; -fx-font-size: 14px; -fx-text-fill: #7a8a99;"/>
    </HBox>

</VBox>