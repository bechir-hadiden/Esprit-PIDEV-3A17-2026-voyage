<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.paint.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.AIGuideController"
      spacing="0" style="-fx-background-color: #f8fafc;" stylesheets="@../css/style.css"
      alignment="TOP_CENTER">
      
    <!-- Coherent & Professional Header (Light Theme) -->
    <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <HBox alignment="CENTER_LEFT" maxWidth="1200" spacing="25" style="-fx-padding: 20 40;">
            <!-- Standard App-styled Back Button -->
            <Button text="←  Retour" onAction="#goBack" 
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #1e293b; -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand;"/>
            
            <Separator orientation="VERTICAL" prefHeight="30" style="-fx-opacity: 0.5;"/>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <StackPane style="-fx-background-color: rgba(37, 99, 235, 0.1); -fx-background-radius: 12; -fx-min-width: 45; -fx-min-height: 45;">
                    <SVGPath content="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4" style="-fx-fill: #2563eb; -fx-scale-x: 1.1; -fx-scale-y: 1.1;"/>
                </StackPane>
                <VBox>
                    <Label text="Assistant Voyage Intelligent" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"/>
                    <Label text="L'IA au service de votre mobilité" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                </VBox>
            </HBox>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
        <VBox alignment="TOP_CENTER" spacing="35">
            <padding>
                <Insets top="50" right="20" bottom="50" left="20"/>
            </padding>

            <!-- Main Form Card -->
            <VBox spacing="35" maxWidth="850" alignment="TOP_LEFT" 
                  style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 45; -fx-effect: dropshadow(three-pass-box, rgba(15, 23, 42, 0.05), 40, 0, 0, 20); -fx-border-color: #f1f5f9; -fx-border-width: 1.5; -fx-border-radius: 24;">
                
                <VBox spacing="8">
                    <Label text="Planifier un nouveau trajet" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #0f172a;"/>
                    <Label text="Remplissez les informations ci-dessous pour obtenir une analyse complète." style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                </VBox>
                
                <GridPane hgap="30" vgap="30">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    
                    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="POINT DE DÉPART" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: 800; -fx-letter-spacing: 1.5;"/>
                        <TextField fx:id="departureField" promptText="Ex: Tunis" 
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15; -fx-font-size: 14px;"/>
                    </VBox>
                    
                    <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="DESTINATION" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: 800; -fx-letter-spacing: 1.5;"/>
                        <TextField fx:id="arrivalField" promptText="Ex: Sousse" 
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15; -fx-font-size: 14px;"/>
                    </VBox>

                    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="PRIORITÉ DU VOYAGE" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: 800; -fx-letter-spacing: 1.5;"/>
                        <ComboBox fx:id="priorityCombo" maxWidth="Infinity" 
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-padding: 10; -fx-background-radius: 12; -fx-border-radius: 12;"/>
                    </VBox>

                    <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="CONTEXTE TEMPOREL" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-weight: 800; -fx-letter-spacing: 1.5;"/>
                        <ComboBox fx:id="timeContextCombo" maxWidth="Infinity" 
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-padding: 10; -fx-background-radius: 12; -fx-border-radius: 12;"/>
                    </VBox>
                </GridPane>

                <Button fx:id="suggestBtn" text="Obtenir une recommandation intelligente" onAction="#handleGetSuggestion" 
                        maxWidth="Infinity" 
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 800; -fx-padding: 18; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(37, 99, 235, 0.2), 20, 0, 0, 10);"/>
            </VBox>

            <!-- Result Section -->
            <VBox fx:id="resultContainer" spacing="30" visible="false" managed="false" alignment="TOP_CENTER">
                <HBox alignment="CENTER" spacing="15">
                    <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.3;"/>
                    <Label text="ANALYSE RÉALISÉE PAR L'IA" style="-fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: #64748b; -fx-letter-spacing: 2px;"/>
                    <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.3;"/>
                </HBox>
                
                <VBox fx:id="recoCardContainer" alignment="CENTER" maxWidth="850" />
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
