<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane styleClass="auth-container" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.demo1.controller.authentification.ForgotPasswordController">
    <HBox alignment="CENTER" maxHeight="800" maxWidth="1200" styleClass="auth-card">
        <!-- Left Side - Form -->
        <VBox prefWidth="600" minWidth="500" maxWidth="600" styleClass="auth-form-section">
            <padding>
                <Insets bottom="40" left="60" right="60" top="40"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="logo-icon">
                    <Region prefHeight="48" prefWidth="48" styleClass="logo-bg"/>
                    <Label styleClass="logo-text" text="S"/>
                </StackPane>
                <Label styleClass="logo-brand" text="SmartTrip"/>
            </HBox>

            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="40"/>
                </VBox.margin>

                <Label styleClass="auth-title" text="Reset Password"/>
                <Label styleClass="auth-subtitle" text="Enter your email to receive a 6-digit code"/>

                <!-- Error / Success Message -->
                <Label fx:id="messageLabel" styleClass="error-message" visible="false" wrapText="true"/>

                <!-- Step Indicators -->
                <HBox alignment="CENTER" spacing="20">
                    <VBox.margin>
                        <Insets top="20" bottom="10"/>
                    </VBox.margin>
                    <Label fx:id="step1Indicator" text="● Step 1" style="-fx-text-fill: #667eea; -fx-font-weight: bold;"/>
                    <Label fx:id="step2Indicator" text="→ Step 2" style="-fx-text-fill: #999;"/>
                    <Label fx:id="step3Indicator" text="→ Step 3" style="-fx-text-fill: #999;"/>
                </HBox>

                <!-- Step 1: Enter Email -->
                <VBox fx:id="step1Box" spacing="20" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="30"/>
                    </VBox.margin>

                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Email Address"/>
                        <TextField fx:id="emailField" promptText="Enter your registered email" styleClass="auth-input"/>
                    </VBox>

                    <Button fx:id="sendCodeButton" maxWidth="Infinity" onAction="#handleSendCode" styleClass="primary-button" text="Send Reset Code"/>
                    <Hyperlink onAction="#handleBackToSignIn" styleClass="auth-link" text="← Back to Sign In"/>
                </VBox>

                <!-- Step 2: Enter Code ONLY -->
                <VBox fx:id="step2Box" spacing="20" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="30"/>
                    </VBox.margin>

                    <Label styleClass="text-muted" text="We sent a 6-digit code to:" wrapText="true"/>
                    <Label fx:id="emailDisplayLabel" styleClass="field-label" style="-fx-font-size: 14px; -fx-text-fill: #667eea;" text=""/>

                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Enter 6-digit code"/>
                        <TextField fx:id="codeField" promptText="000000" styleClass="auth-input" maxWidth="200"/>
                    </VBox>

                    <Button fx:id="verifyCodeButton" maxWidth="Infinity" onAction="#handleVerifyCode" styleClass="primary-button" text="Verify Code"/>
                    <Hyperlink onAction="#handleBackToStep1" styleClass="auth-link" text="← Use different email"/>
                </VBox>

                <!-- Step 3: New Password ONLY -->
                <VBox fx:id="step3Box" spacing="20" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="30"/>
                    </VBox.margin>

                    <Label styleClass="text-muted" text="Create a new secure password" wrapText="true"/>

                    <VBox spacing="8">
                        <Label styleClass="field-label" text="New Password"/>
                        <PasswordField fx:id="newPasswordField" promptText="At least 6 characters" styleClass="auth-input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Confirm Password"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="auth-input"/>
                    </VBox>

                    <Button fx:id="resetButton" maxWidth="Infinity" onAction="#handleResetPassword" styleClass="primary-button" text="Reset Password"/>
                    <Hyperlink onAction="#handleBackToStep2" styleClass="auth-link" text="← Back to verification"/>
                </VBox>

                <!-- Step 4: Success Message -->
                <VBox fx:id="step4Box" spacing="20" visible="false" managed="false" alignment="CENTER" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="50"/>
                    </VBox.margin>

                    <Label text="✓" style="-fx-font-size: 60; -fx-text-fill: #22C55E;"/>
                    <Label styleClass="auth-title" text="Success!" style="-fx-text-fill: #22C55E;"/>
                    <Label styleClass="text-muted" text="Your password has been reset." wrapText="true"/>
                    <Button maxWidth="Infinity" onAction="#handleBackToSignIn" styleClass="primary-button" text="Go to Sign In"/>
                </VBox>
            </VBox>
        </VBox>

        <!-- Right Side - Info -->
        <VBox prefWidth="600" minWidth="500" maxWidth="600" styleClass="auth-features-section">
            <padding>
                <Insets bottom="60" left="60" right="60" top="60"/>
            </padding>
            <VBox spacing="20" VBox.vgrow="ALWAYS">
                <Label styleClass="features-title" text="Forgot password?" wrapText="true"/>
                <Label styleClass="features-description" text="Follow these 3 simple steps to reset your password securely." wrapText="true">
                    <VBox.margin>
                        <Insets top="20"/>
                    </VBox.margin>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="feature-item">
                    <StackPane styleClass="feature-icon-bg">
                        <Region prefHeight="40" prefWidth="40"/>
                        <Label styleClass="feature-icon" text="1"/>
                    </StackPane>
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Enter Email"/>
                        <Label style="-fx-font-size: 12; -fx-text-fill: #64748b;" text="Provide your registered email address"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="feature-item">
                    <StackPane styleClass="feature-icon-bg">
                        <Region prefHeight="40" prefWidth="40"/>
                        <Label styleClass="feature-icon" text="2"/>
                    </StackPane>
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Verify Code"/>
                        <Label style="-fx-font-size: 12; -fx-text-fill: #64748b;" text="Enter the 6-digit code from your email"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="feature-item">
                    <StackPane styleClass="feature-icon-bg">
                        <Region prefHeight="40" prefWidth="40"/>
                        <Label styleClass="feature-icon" text="3"/>
                    </StackPane>
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="New Password"/>
                        <Label style="-fx-font-size: 12; -fx-text-fill: #64748b;" text="Create a strong new password"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
