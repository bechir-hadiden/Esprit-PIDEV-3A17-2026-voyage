<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane styleClass="auth-container" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.demo1.controller.authentification.SignUpController">
    <HBox alignment="CENTER" maxHeight="900" maxWidth="1200" styleClass="auth-card">
        <!-- Left Side - Form -->
        <VBox styleClass="auth-form-section" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="40" left="60" right="60" top="40"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="logo-icon">
                    <Region prefHeight="48" prefWidth="48" styleClass="logo-bg"/>
                    <Label styleClass="logo-text" text="S"/>
                </StackPane>
                <Label styleClass="logo-brand" text="SmartTrip"/>
            </HBox>

            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="30"/>
                </VBox.margin>

                <Label styleClass="auth-title" text="Create Account"/>
                <Label styleClass="auth-subtitle" text="Join SmartTrip and start your travel journey today"/>

                <!-- Error Message -->
                <Label fx:id="errorLabel" styleClass="error-message" visible="false" wrapText="true"/>

                <!-- Form -->
                <VBox spacing="16" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="25"/>
                    </VBox.margin>

                    <!-- Full Name -->
                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Full Name"/>
                        <TextField fx:id="fullNameField" promptText="John Doe" styleClass="auth-input"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Email Address"/>
                        <TextField fx:id="emailField" promptText="you@example.com" styleClass="auth-input"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Password"/>
                        <PasswordField fx:id="passwordField" promptText="Create a password" styleClass="auth-input"/>
                        <Label styleClass="hint-text" text="Must be at least 6 characters"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="8">
                        <Label styleClass="field-label" text="Confirm Password"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" styleClass="auth-input"/>
                    </VBox>

                    <!-- Terms Checkbox -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <CheckBox fx:id="termsCheck" styleClass="terms-checkbox"/>
                        <Label styleClass="terms-text" text="I agree to the" wrapText="true"/>
                        <Hyperlink onAction="#handleTerms" styleClass="terms-link" text="Terms of Service"/>
                        <Label styleClass="terms-text" text="and"/>
                        <Hyperlink onAction="#handlePrivacy" styleClass="terms-link" text="Privacy Policy"/>
                    </HBox>

                    <!-- Sign Up Button -->
                    <Button fx:id="signUpButton" maxWidth="Infinity" onAction="#handleSignUp" styleClass="primary-button" text="Create Account">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>

                    <!-- Sign In Link -->
                    <HBox alignment="CENTER" spacing="5">
                        <Label styleClass="text-muted" text="Already have an account?"/>
                        <Hyperlink onAction="#handleSignIn" styleClass="auth-link" text="Sign in"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <!-- Right Side - Benefits -->
        <VBox styleClass="auth-features-section" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="60" left="60" right="60" top="60"/>
            </padding>

            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <Label styleClass="features-title" text="Start Your" wrapText="true"/>
                <Label styleClass="features-highlight" text="Adventure" wrapText="true"/>

                <Label styleClass="features-description" text="Create an account today and unlock exclusive benefits designed for modern travelers." wrapText="true">
                    <VBox.margin>
                        <Insets top="20"/>
                    </VBox.margin>
                </Label>

                <!-- Benefits List -->
                <VBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="40"/>
                    </VBox.margin>

                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="benefit-item">
                        <StackPane styleClass="benefit-icon-bg">
                            <Region prefHeight="32" prefWidth="32"/>
                            <Label styleClass="benefit-icon" text="✓"/> <!-- Check icon -->
                        </StackPane>
                        <Label styleClass="benefit-text" text="Save your favorite hotels and destinations"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="benefit-item">
                        <StackPane styleClass="benefit-icon-bg">
                            <Region prefHeight="32" prefWidth="32"/>
                            <Label styleClass="benefit-icon" text="✓"/>
                        </StackPane>
                        <Label styleClass="benefit-text" text="Get personalized travel recommendations"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="benefit-item">
                        <StackPane styleClass="benefit-icon-bg">
                            <Region prefHeight="32" prefWidth="32"/>
                            <Label styleClass="benefit-icon" text="✓"/>
                        </StackPane>
                        <Label styleClass="benefit-text" text="Earn rewards on every booking"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="benefit-item">
                        <StackPane styleClass="benefit-icon-bg">
                            <Region prefHeight="32" prefWidth="32"/>
                            <Label styleClass="benefit-icon" text="✓"/>
                        </StackPane>
                        <Label styleClass="benefit-text" text="Access exclusive member-only deals"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
