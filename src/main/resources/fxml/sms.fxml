<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo1.controller.SmsController"
            style="-fx-background-color: #EAF3FF;">

    <!-- EN-TETE -->
    <top>
        <VBox style="-fx-background-color: #083D77; -fx-padding: 24 30 20 30;" spacing="4">
            <Label text="SMARTTRIP — MESSAGERIE"
                   style="-fx-font-family: 'Georgia'; -fx-font-size: 9px;
                          -fx-letter-spacing: 3px; -fx-text-fill: rgba(255,255,255,0.45);"/>
            <Label text="Envoyer un SMS client"
                   style="-fx-font-family: 'Georgia'; -fx-font-size: 20px;
                          -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Via Twilio SMS — Rapide et fiable"
                   style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.3);"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #EAF3FF; -fx-background: #EAF3FF;
                           -fx-border-color: transparent;">
            <VBox spacing="18" style="-fx-padding: 24 30 28 30;">

                <!-- ================================================
                     TEST DE CONNEXION
                ================================================ -->
                <VBox fx:id="panelTestBox" spacing="12"
                      style="-fx-background-color: white; -fx-padding: 20;
                             -fx-background-radius: 12;
                             -fx-border-color: #0A6CF1; -fx-border-width: 1.5;
                             -fx-border-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(10,108,241,0.15), 12, 0, 0, 4);">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <VBox HBox.hgrow="ALWAYS" spacing="3">
                            <Label text="TEST DE CONNEXION TWILIO"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 9px;
                                          -fx-letter-spacing: 3px; -fx-text-fill: #0A6CF1;"/>
                            <Label text="Verifier que vos credentials fonctionnent"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 12px;
                                          -fx-text-fill: #6b7f99;"/>
                        </VBox>
                        <ProgressIndicator fx:id="progressTest" prefWidth="22" prefHeight="22"/>
                    </HBox>

                    <Button text="Tester la connexion Twilio"
                            onAction="#testerConnexion"
                            maxWidth="Infinity"
                            style="-fx-background-color: #EAF3FF; -fx-text-fill: #0A6CF1;
                                   -fx-font-family: 'Georgia'; -fx-font-size: 12px;
                                   -fx-font-weight: bold; -fx-padding: 11 0;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #0A6CF1; -fx-border-width: 1.5;
                                   -fx-border-radius: 8;"/>

                    <HBox fx:id="panelTestResult" spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color: #EAF3FF; -fx-padding: 10 14;
                                 -fx-background-radius: 8;">
                        <Label fx:id="lblTestStatut" text="" wrapText="true"
                               style="-fx-font-size: 11px; -fx-text-fill: #4caf50;"/>
                    </HBox>
                </VBox>

                <!-- ================================================
                     TYPE DE MESSAGE
                ================================================ -->
                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-padding: 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(8,61,119,0.08), 10, 0, 0, 3);">
                    <Label text="TYPE DE MESSAGE"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 9px;
                                  -fx-letter-spacing: 3px; -fx-text-fill: #0A6CF1;"/>
                    <ComboBox fx:id="cbTypeMessage" maxWidth="Infinity"
                              style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                     -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                     -fx-border-color: transparent; -fx-padding: 4;"/>
                </VBox>

                <!-- ================================================
                     INFORMATIONS CLIENT
                ================================================ -->
                <VBox spacing="14"
                      style="-fx-background-color: white; -fx-padding: 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(8,61,119,0.08), 10, 0, 0, 3);">

                    <Label text="INFORMATIONS CLIENT"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 9px;
                                  -fx-letter-spacing: 3px; -fx-text-fill: #0A6CF1;"/>

                    <VBox spacing="5">
                        <Label text="Numero de telephone *"
                               style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                        <TextField fx:id="txtNumero"
                                   promptText="Ex: 21698765432 (avec ou sans +)"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                          -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        <Label text="Format international : code pays + numero (Ex: 21698765432)"
                               style="-fx-font-size: 9px; -fx-text-fill: #aab8cc;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Nom du client"
                               style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                        <TextField fx:id="txtNomClient"
                                   promptText="Ex: Mohamed Ali"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                          -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-border-color: transparent;"/>
                    </VBox>
                </VBox>

                <!-- ================================================
                     INFORMATIONS VOYAGE
                ================================================ -->
                <VBox spacing="14"
                      style="-fx-background-color: white; -fx-padding: 20;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(8,61,119,0.08), 10, 0, 0, 3);">

                    <Label text="INFORMATIONS VOYAGE"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 9px;
                                  -fx-letter-spacing: 3px; -fx-text-fill: #0A6CF1;"/>

                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Destination"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtDestination" promptText="Ex: Dubai"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Pays"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtPays" promptText="Ex: Emirats Arabes Unis"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Date de depart"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtDateDepart" promptText="Ex: 15/03/2025"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Date de retour"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtDateFin" promptText="Ex: 22/03/2025"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Hotel"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtHotel" promptText="Ex: Burj Al Arab"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Prix (TND)"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                          -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                            <TextField fx:id="txtPrix" promptText="Ex: 2500"
                                       style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                              -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-border-color: transparent;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="Reference dossier"
                               style="-fx-font-family: 'Georgia'; -fx-font-size: 11px;
                                      -fx-font-weight: bold; -fx-text-fill: #083D77;"/>
                        <TextField fx:id="txtReference" promptText="Ex: ST-2025-1234"
                                   style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;
                                          -fx-background-color: #EAF3FF; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-border-color: transparent;"/>
                    </VBox>
                </VBox>

                <!-- ================================================
                     BOUTON ENVOYER
                ================================================ -->
                <VBox spacing="10">
                    <Button text="📱 Envoyer le SMS"
                            onAction="#envoyer"
                            maxWidth="Infinity"
                            style="-fx-background-color: #0A6CF1; -fx-text-fill: white;
                                   -fx-font-family: 'Georgia'; -fx-font-size: 14px;
                                   -fx-font-weight: bold; -fx-padding: 14 0;
                                   -fx-background-radius: 10; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(10,108,241,0.4), 12, 0, 0, 4);"/>

                    <HBox alignment="CENTER" spacing="10">
                        <ProgressIndicator fx:id="progressIndicator" prefWidth="20" prefHeight="20"/>
                        <Label fx:id="lblStatut" text=""
                               style="-fx-font-family: 'Georgia'; -fx-font-size: 12px;"/>
                    </HBox>
                </VBox>

                <!-- ================================================
                     NOTE COMPTE TRIAL
                ================================================ -->
                <VBox spacing="6"
                      style="-fx-background-color: #FFF8E1; -fx-padding: 16;
                             -fx-background-radius: 10;
                             -fx-border-color: #FFD54F; -fx-border-width: 1;
                             -fx-border-radius: 10;">
                    <Label text="COMPTE TRIAL TWILIO"
                           style="-fx-font-size: 9px; -fx-letter-spacing: 2px;
                                  -fx-font-weight: bold; -fx-text-fill: #F57F17;"/>
                    <Label text="En mode Trial, vous ne pouvez envoyer des SMS qu'aux numeros verifies dans votre compte Twilio."
                           style="-fx-font-size: 11px; -fx-text-fill: #795548;" wrapText="true"/>
                    <Label text="Twilio Console > Phone Numbers > Verified Caller IDs > ajouter votre numero"
                           style="-fx-font-size: 10px; -fx-text-fill: #aaa;" wrapText="true"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
