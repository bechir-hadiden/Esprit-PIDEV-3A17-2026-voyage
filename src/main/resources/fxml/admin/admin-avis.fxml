<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="24" styleClass="content-container" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.admin.AdminAvisController">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox>
            <Label styleClass="welcome-title" text="Administration des Avis 👑" wrapText="true">
                <font>
                    <Font name="System Bold" size="28"/>
                </font>
            </Label>
            <Label styleClass="welcome-subtitle" text="Gérez tous les avis des utilisateurs (consultation, modification, suppression)" textFill="#64748B"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAjouter" text="+ Nouvel avis" styleClass="primary-button"/>
    </HBox>

    <!-- Statistiques rapides -->
    <HBox spacing="16">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <StackPane styleClass="stat-icon-bg, blue">
                <Region prefHeight="40" prefWidth="40"/>
                <Label styleClass="stat-icon" text="📝" textFill="#2563EB"/>
            </StackPane>
            <Label fx:id="lblTotalAvis" styleClass="stat-value" text="0" textFill="#2563EB"/>
            <Label styleClass="stat-label" text="Total avis"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <StackPane styleClass="stat-icon-bg, green">
                <Region prefHeight="40" prefWidth="40"/>
                <Label styleClass="stat-icon" text="⭐" textFill="#22C55E"/>
            </StackPane>
            <Label fx:id="lblNoteMoyenne" styleClass="stat-value" text="0" textFill="#22C55E"/>
            <Label styleClass="stat-label" text="Note moyenne"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <StackPane styleClass="stat-icon-bg, orange">
                <Region prefHeight="40" prefWidth="40"/>
                <Label styleClass="stat-icon" text="📅" textFill="#F97316"/>
            </StackPane>
            <Label fx:id="lblAvisMois" styleClass="stat-value" text="0" textFill="#F97316"/>
            <Label styleClass="stat-label" text="Ce mois"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <StackPane styleClass="stat-icon-bg, purple">
                <Region prefHeight="40" prefWidth="40"/>
                <Label styleClass="stat-icon" text="🏨" textFill="#9333EA"/>
            </StackPane>
            <Label fx:id="lblVoyagesNotes" styleClass="stat-value" text="0" textFill="#9333EA"/>
            <Label styleClass="stat-label" text="Voyages notés"/>
        </VBox>
    </HBox>

    <!-- Barre de recherche avancée -->
    <VBox spacing="16" styleClass="card">
        <Label styleClass="card-title" text="🔍 Recherche avancée"/>

        <GridPane hgap="16" vgap="12">
            <!-- Ligne 1 -->
            <Label text="Recherche:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
            <TextField fx:id="txtRecherche" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="search-field" promptText="Nom, email ou commentaire..."/>

            <Label text="Filtrer par note:" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="field-label"/>
            <ComboBox fx:id="comboFiltreNote" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="combo-box" prefWidth="120"/>

            <!-- Ligne 2 -->
            <Label text="Filtrer par voyage:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
            <TextField fx:id="txtFiltreVoyageId" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="search-field" promptText="ID du voyage"/>

            <Label text="Période:" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="field-label"/>
            <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="3" alignment="CENTER_LEFT">
                <DatePicker fx:id="dateDebut" promptText="Date début" styleClass="date-picker" prefWidth="120"/>
                <Label text="à" style="-fx-text-fill: #6c757d;"/>
                <DatePicker fx:id="dateFin" promptText="Date fin" styleClass="date-picker" prefWidth="120"/>
            </HBox>

            <!-- Ligne 3 - Boutons -->
            <HBox spacing="16" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="4" alignment="CENTER_RIGHT">
                <Button fx:id="btnRechercher" text="🔍 Rechercher" styleClass="primary-button"/>
                <Button fx:id="btnReset" text="🔄 Réinitialiser" styleClass="secondary-button"/>
                <Button fx:id="btnExporterPDF" text="📄 Exporter PDF" styleClass="accent-button"/>
            </HBox>

            <padding>
                <Insets bottom="8" left="8" right="8" top="8"/>
            </padding>
        </GridPane>
    </VBox>

    <!-- Liste des avis avec gestion admin -->
    <VBox spacing="16" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label styleClass="section-title" text="📋 Liste des avis"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblResultatRecherche" styleClass="tag" text="0 avis"/>
        </HBox>

        <TableView fx:id="tableViewAvis" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" resizable="false"/>
                <TableColumn fx:id="colNom" text="Nom client" prefWidth="150"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                <TableColumn fx:id="colNote" text="Note" prefWidth="100"/>
                <TableColumn fx:id="colCommentaire" text="Commentaire" prefWidth="300"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                <TableColumn fx:id="colVoyageId" text="Voyage #" prefWidth="80"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="180"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>