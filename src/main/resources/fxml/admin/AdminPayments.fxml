<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="admin-content" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.admin.AdminPaymentsController" spacing="20">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox styleClass="admin-header" alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label styleClass="admin-title" text="Journal des paiements"/>
            <Label styleClass="admin-subtitle-header" text="Consultation et gestion des transactions financi&#232;res"/>
        </VBox>
        <Button styleClass="admin-button-secondary" text="Refresh" onAction="#handleRefresh"/>
        <Button styleClass="admin-button-secondary" text="Afficher paiements r&#233;alis&#233;s" onAction="#handleShowRealizedPayments"/>
        <Button styleClass="admin-button-secondary" text="Open Stripe Dashboard" onAction="#handleOpenStripe"/>
    </HBox>

    <!-- Bulk Actions Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="admin-card" style="-fx-padding: 10;">
        <ComboBox promptText="-- S&#233;lectionner une action --" prefWidth="200"/>
        <Button styleClass="admin-button-primary" text="Appliquer &#8594;" style="-fx-background-color: #0f172a; -fx-text-fill: white;"/>
    </HBox>

    <!-- Search and Filter Bar -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by User or ID..." prefWidth="250" styleClass="admin-text-field"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label styleClass="admin-form-label" text="Filter:"/>
        <ComboBox fx:id="statusFilter" promptText="All Statuses"/>
    </HBox>

    <!-- Payments Table -->
    <VBox styleClass="admin-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="paymentsTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="selectColumn" prefWidth="40" text="&#9744;"/>
                <TableColumn fx:id="dateColumn" text="DATE" prefWidth="150"/>
                <TableColumn fx:id="userColumn" text="CLIENT" prefWidth="200"/>
                <TableColumn fx:id="bookingColumn" text="R&#201;SERVATION #" prefWidth="120"/>
                <TableColumn fx:id="amountColumn" text="MONTANT" prefWidth="120"/>
                <TableColumn fx:id="methodColumn" text="M&#201;THODE" prefWidth="180"/>
                <TableColumn fx:id="statusColumn" text="STATUT" prefWidth="100"/>
                <TableColumn fx:id="aiColumn" text="ANALYSE IA" prefWidth="150"/>
                <TableColumn fx:id="actionsColumn" text="ACTIONS" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No payments found."/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
