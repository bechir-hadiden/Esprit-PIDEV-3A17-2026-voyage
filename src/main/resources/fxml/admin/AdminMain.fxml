<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.controller.admin.AdminMainController"
            stylesheets="@../../css/main.css,@../../css/admin-styles.css">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="admin-sidebar">
            <!-- Header -->
            <VBox styleClass="admin-sidebar-header">
                <Label styleClass="admin-logo" text="✈️ SmartTrip"/>
                <Label fx:id="adminNameLabel" styleClass="admin-subtitle" text="Espace Administrateur"/>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="24" bottom="24" left="16" right="16"/>
                </padding>

                <Button fx:id="dashboardButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="📊 Tableaux de bord" onAction="#showDashboard"/>
                <Button fx:id="hotelsButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="🏨 Hébergements" onAction="#showHotels"/>
                <Button fx:id="transportButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="🚗 Flotte &amp; Déplacements" onAction="#showTransport"/>
                <Button fx:id="offersButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="🌴 Offres de Voyage" onAction="#showOffers"/>
                <Button fx:id="plansButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="⭐ Abonnements" onAction="#showPlans"/>
                <Button fx:id="paymentsButton" maxWidth="Infinity" styleClass="admin-nav-item"
                        text="💳 Paiements" onAction="#showPayments"/>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- Logout Section - Redesigned -->
            <VBox styleClass="logout-section" spacing="12">
                <padding>
                    <Insets bottom="24" left="16" right="16"/>
                </padding>
                <Separator styleClass="sidebar-separator"/>
                <Button maxWidth="Infinity" styleClass="admin-nav-item, logout-button"
                        text="🚪 Déconnexion" onAction="#handleLogout"/>

            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox>
            <!-- Top Header Bar -->
            <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar">
                <padding>
                    <Insets top="16" right="24" bottom="16" left="24"/>
                </padding>

                <Label fx:id="contentTitle" styleClass="admin-page-title" text="Dashboard"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Profile Button -->
                <Button onAction="#showSettings" styleClass=" top-bar-button">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <Label styleClass="top-bar-icon" text="👤"/> <!-- Profile -->
                            <Label text="Profile"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <!-- Content Area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>
