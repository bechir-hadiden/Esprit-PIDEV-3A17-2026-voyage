<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="30" styleClass="admin-content-container" stylesheets="@../../css/main.css,@../../css/admin-styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controller.admin.AdminReservationsController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button onAction="#handleBack" text="⬅ Retour" styleClass="admin-button-secondary" />
        <VBox>
            <Label styleClass="admin-section-title" text="Gestion des Réservations" />
            <Label style="-fx-text-fill: #64748b;" text="Visualisez et modifiez le statut des réservations de transport" />
        </VBox>
    </HBox>

    <VBox spacing="25" VBox.vgrow="ALWAYS" styleClass="admin-card" style="-fx-padding: 35; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 30, 0, 0, 15); -fx-background-color: white;" maxWidth="Infinity">
        <HBox alignment="CENTER_LEFT" spacing="25">
            <StackPane styleClass="stat-icon-container" style="-fx-background-color: #0f172a; -fx-padding: 20; -fx-background-radius: 15;">
                <Label style="-fx-font-size: 32px; -fx-text-fill: white;" text="📅" />
            </StackPane>
            <VBox spacing="8">
                <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Liste des Réservations" />
                <Label style="-fx-font-size: 18px; -fx-text-fill: #475569; -fx-font-weight: 500;" text="Contrôle total des flux de transport" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#refreshReservations" text="🔄 ACTUALISER LA LISTE" 
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: 900; -fx-background-radius: 12; -fx-padding: 15 35; -fx-cursor: hand; -fx-font-size: 16px;" />
        </HBox>

        <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS" minHeight="500" 
                  style="-fx-selection-bar: #f8fafc; -fx-font-size: 14px; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="100" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                <TableColumn fx:id="colUser" text="👤 Client" prefWidth="250" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 20;" />
                <TableColumn fx:id="colTransport" text="🚌 Catégorie" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDate" text="⏰ Date &amp; Heure" prefWidth="250" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colStatus" text="📊 État Actuel" prefWidth="180" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colActions" text="⚡ Actions" prefWidth="220" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
