<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" stylesheets="@../../css/style2.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controller.admin.GestionCodesController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label fx:id="lblTitreOffre" styleClass="label-title" text="Gestion des Coupons" />

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Formulaire à gauche -->
                        <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                            <children>
                                <Label text="Nouveau Code :">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtCode" promptText="Ex: ETE2026" />

                                <Button onAction="#handleGenererMetier" prefWidth="200.0" style="-fx-background-color: #34495E; -fx-text-fill: white;" text="Générer Aléatoirement 🎲" />

                                <Separator />

                                <Label text="Date d'expiration :" />
                                <DatePicker fx:id="dpExpiration" prefWidth="200.0" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button onAction="#handleAjouter" prefWidth="200.0" styleClass="btn-add" text="Ajouter le Coupon" />
                            </children>
                        </VBox>

                        <!-- Tableau à droite -->
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <TableView fx:id="tableCodes" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colCode" prefWidth="150.0" text="Code Coupon" />
                                        <TableColumn fx:id="colExpire" prefWidth="150.0" text="Date Limite" />
                                    </columns>
                                </TableView>
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button onAction="#handleExportPDF" style="-fx-background-color: #E74C3C; -fx-text-fill: white;" text="Exporter PDF 📄" />
                                        <Button onAction="#handleSupprimer" styleClass="btn-delete" text="Supprimer" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>