<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.admin.AdminUsersController"
      spacing="20" styleClass="admin-content">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Stats Cards -->
    <HBox spacing="16">
        <VBox style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 16;" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
            <Label text="Total Users" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
        </VBox>
        <VBox style="-fx-background-color: #f0fdf4; -fx-background-radius: 12; -fx-padding: 16;" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label fx:id="activeUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
            <Label text="Active" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
        </VBox>
        <VBox style="-fx-background-color: #fef2f2; -fx-background-radius: 12; -fx-padding: 16;" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label fx:id="blockedUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
            <Label text="Blocked" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
        </VBox>
        <VBox style="-fx-background-color: #fffbeb; -fx-background-radius: 12; -fx-padding: 16;" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
            <Label fx:id="adminsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
            <Label text="Admins" style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <TextField fx:id="searchField" promptText="Search users..." prefWidth="260"
                   style="-fx-background-radius: 8; -fx-padding: 8 12; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"/>
        <ComboBox fx:id="filterComboBox" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 16;"/>
        <Button text="+ Add User" onAction="#handleAddUser"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 16;"/>
    </HBox>

    <!-- Message Label -->
    <Label fx:id="messageLabel" text="" visible="false" wrapText="true"/>

    <!-- Users Table -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="avatarColumn" text="" prefWidth="60" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="160"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="180" style="-fx-alignment: CENTER;"/>
        </columns>
        <placeholder>
            <Label text="No users found"/>
        </placeholder>
    </TableView>
</VBox>
