<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.admin.AdminUsersController"
      style="-fx-background-color: #f8fafc; -fx-padding: 30;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="👥" style="-fx-font-size: 32;"/>
        <VBox>
            <Label text="User Management" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Manage users and their access" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="🔄 Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6;"/>
    </HBox>

    <!-- Stats Cards -->
    <HBox spacing="15">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="Total Users" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="Active Users" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
            <Label fx:id="activeUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="Blocked Users" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
            <Label fx:id="blockedUsersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="Admins" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
            <Label fx:id="adminsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
        </VBox>
    </HBox>

    <!-- Search and Filter -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Search by name or email..."
                   style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10 15; -fx-font-size: 14; -fx-pref-width: 300;"/>
        <ComboBox fx:id="filterComboBox" promptText="All Users"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addUserButton" text="➕ Add User" onAction="#handleAddUser"
                style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6;"/>
    </HBox>

    <!-- Users Table -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="avatarColumn" text="" prefWidth="60"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="250"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Message Label -->
    <Label fx:id="messageLabel" visible="false" wrapText="true"
           style="-fx-padding: 10; -fx-background-radius: 6;"/>

</VBox>
