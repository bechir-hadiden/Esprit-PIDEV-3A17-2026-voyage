<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="750.0" prefWidth="1050.0" stylesheets="@../../css/style2.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controller.admin.AfficherOffresController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            <children>

                <!-- 1. EN-TÊTE : Titre et Recherche -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label styleClass="label-title" text="Gestion des promotions" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtRecherche" prefHeight="40.0" prefWidth="280.0" promptText="Rechercher par titre..." styleClass="text-field" />
                    </children>
                </HBox>

                <!-- 2. NOUVEAU : DASHBOARD STATISTIQUE -->
                <HBox prefHeight="180.0" spacing="30.0" styleClass="main-card">
                    <padding>
                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                    </padding>
                    <children>
                        <!-- Indicateurs Chiffrés -->
                        <VBox alignment="CENTER_LEFT" spacing="15.0" prefWidth="250.0">
                            <children>
                                <Label text="ANALYSE DES OFFRES" style="-fx-font-weight: bold; -fx-text-fill: #64748B; -fx-font-size: 13px;" />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Total Offres :" style="-fx-font-size: 14px;"/>
                                    <Label fx:id="lblTotal" text="0" style="-fx-font-weight: bold; -fx-text-fill: #1A73E8; -fx-font-size: 18px;" />
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Impact ODD 8 :" style="-fx-font-size: 14px;"/>
                                    <Label fx:id="lblODDCount" text="0" style="-fx-font-weight: bold; -fx-text-fill: #27AE60; -fx-font-size: 18px;" />
                                </HBox>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Graphique Circulaire -->
                        <PieChart fx:id="statChart" prefHeight="150.0" prefWidth="350.0" title="Répartition par Catégorie" />
                    </children>
                </HBox>

                <!-- 3. LA CARTE DU TABLEAU -->
                <VBox spacing="20.0" styleClass="main-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
                    </padding>
                    <children>
                        <TableView fx:id="tableOffres" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="60.0" minWidth="50.0" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colTitre" prefWidth="200.0" text="Titre" />
                                <TableColumn fx:id="colRemise" prefWidth="100.0" text="Remise (%)" />
                                <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
                                <TableColumn fx:id="colODD" prefWidth="180.0" text="Impact ODD 8" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- Boutons d'action -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button onAction="#handleGererCodes" styleClass="btn-update" text="Gérer les Coupons" />
                                <Button onAction="#handleModifier" styleClass="btn-update" text="Modifier" />
                                <Button onAction="#handleSupprimer" styleClass="btn-delete" text="Supprimer" />
                                <Button onAction="#handleAjouter" styleClass="btn-add" text="Créer une Offre" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>