<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@../../css/style2.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controller.admin.AfficherOffresController">
    <children>
        <!-- Conteneur principal avec fond gris clair (#F4F7FB via CSS) -->
        <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>

                <!-- 1. EN-TÊTE : Titre et Recherche -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label styleClass="label-title" text="Gestion des promotions" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtRecherche" prefHeight="42.0" prefWidth="280.0" promptText="Rechercher par titre..." styleClass="text-field" />
                    </children>
                </HBox>

                <!-- 2. LA CARTE BLANCHE (Steps 1, 6, 8) -->
                <!-- Ce conteneur regroupe le tableau et les boutons sur un fond blanc avec ombre -->
                <VBox spacing="20.0" styleClass="main-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>

                        <!-- Le Tableau (Vgrow ALWAYS pour remplir la carte) -->
                        <TableView fx:id="tableOffres" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="60.0" minWidth="50.0" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colTitre" prefWidth="200.0" text="Titre" />
                                <TableColumn fx:id="colRemise" prefWidth="100.0" text="Remise (%)" />
                                <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
                                <TableColumn fx:id="colODD" prefWidth="180.0" text="Impact ODD 8" />
                            </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                        </TableView>

                        <!-- 3. BOUTONS D'ACTION (Alignés à droite dans la carte) -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button fx:id="btnGererCodes" mnemonicParsing="false" onAction="#handleGererCodes" styleClass="btn-update" text="Gérer les Coupons" />
                                <Button fx:id="btnModifier" mnemonicParsing="false" onAction="#handleModifier" styleClass="btn-update" text="Modifier" />
                                <Button fx:id="btnSupprimer" mnemonicParsing="false" onAction="#handleSupprimer" styleClass="btn-delete" text="Supprimer" />
                                <Button fx:id="btnAjouter" mnemonicParsing="false" onAction="#handleAjouter" styleClass="btn-add" text="Créer une Offre" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
