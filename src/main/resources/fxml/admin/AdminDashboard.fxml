<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="admin-content" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.admin.AdminDashboardController" spacing="30">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox styleClass="admin-header" alignment="CENTER_LEFT">
        <VBox>
            <Label styleClass="admin-title" text="Dashboard"/>
            <Label styleClass="admin-subtitle-header" text="Overview of your travel management system"/>
        </VBox>
    </HBox>

    <!-- Stats Cards -->
    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
        </columnConstraints>

        <VBox styleClass="stat-card" GridPane.columnIndex="0">
            <Label fx:id="hotelCountLabel" styleClass="stat-value" text="0"/>
            <Label styleClass="stat-label" text="Total Hotels"/>
        </VBox>

        <VBox styleClass="stat-card" GridPane.columnIndex="1">
            <Label styleClass="stat-value" text="Coming Soon"/>
            <Label styleClass="stat-label" text="Transport Options"/>
        </VBox>

        <VBox styleClass="stat-card" GridPane.columnIndex="2">
            <Label styleClass="stat-value" text="Coming Soon"/>
            <Label styleClass="stat-label" text="Active Offers"/>
        </VBox>

        <VBox styleClass="stat-card" GridPane.columnIndex="3">
            <Label styleClass="stat-value" text="Coming Soon"/>
            <Label styleClass="stat-label" text="Subscription Plans"/>
        </VBox>
    </GridPane>

    <!-- Quick Actions -->
    <VBox styleClass="admin-card" spacing="20">
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Quick Actions"/>
        <HBox spacing="15">
            <Button styleClass="admin-button-primary" text="➕ Add New Hotel" onAction="#handleAddHotel"/>
            <Button styleClass="admin-button-secondary" text="📊 View All Hotels" onAction="#handleViewHotels"/>
        </HBox>
    </VBox>

</VBox>
