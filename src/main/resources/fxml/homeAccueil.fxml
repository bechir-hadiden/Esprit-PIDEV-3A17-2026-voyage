<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo1.controller.HomeAccueilController"
            fitToWidth="true"
            styleClass="content-scroll">

    <VBox spacing="0" styleClass="accueil-container">

        <!-- HERO SECTION -->
        <VBox styleClass="hero-section" alignment="CENTER" spacing="20">
            <padding>
                <Insets top="80" right="40" bottom="80" left="40"/>
            </padding>

            <Label text="Explorez le Monde avec Nous" styleClass="hero-title"/>
            <Label text="Découvrez des destinations exceptionnelles et créez des souvenirs inoubliables"
                   styleClass="hero-subtitle"/>

            <HBox spacing="15" alignment="CENTER">
                <padding>
                    <Insets top="20"/>
                </padding>
                <Button text="🌍 Découvrir nos voyages" styleClass="btn-primary-large"/>
                <Button text="📞 Nous contacter" styleClass="btn-secondary-large"
                        onAction="#showContact"/>
                <Button text="✈️ Rechercher un Vol"
                        onAction="#ouvrirRechercheVols"
                        style="-fx-background-color: #48c774; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>

        <!-- STATISTIQUES -->
        <HBox styleClass="stats-section" spacing="40" alignment="CENTER">
            <padding>
                <Insets top="60" right="40" bottom="60" left="40"/>
            </padding>

            <VBox styleClass="stat-box" alignment="CENTER" spacing="10">
                <Label text="500+" styleClass="stat-number"/>
                <Label text="Voyages organisés" styleClass="stat-label"/>
            </VBox>

            <Separator orientation="VERTICAL" prefHeight="60"/>

            <VBox styleClass="stat-box" alignment="CENTER" spacing="10">
                <Label text="50+" styleClass="stat-number"/>
                <Label text="Destinations" styleClass="stat-label"/>
            </VBox>

            <Separator orientation="VERTICAL" prefHeight="60"/>

            <VBox styleClass="stat-box" alignment="CENTER" spacing="10">
                <Label text="2000+" styleClass="stat-number"/>
                <Label text="Clients satisfaits" styleClass="stat-label"/>
            </VBox>

            <Separator orientation="VERTICAL" prefHeight="60"/>

            <VBox styleClass="stat-box" alignment="CENTER" spacing="10">
                <Label text="15+" styleClass="stat-number"/>
                <Label text="Années d'expérience" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <!-- DESTINATIONS POPULAIRES -->
        <VBox styleClass="section" spacing="30">
            <padding>
                <Insets top="60" right="40" bottom="60" left="40"/>
            </padding>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Destinations Populaires" styleClass="section-title"/>
                <Label text="Les endroits les plus demandés par nos voyageurs"
                       styleClass="section-subtitle"/>
            </VBox>


            <HBox spacing="30" alignment="CENTER">
                <!-- Destination Card 1 -->
                <VBox styleClass="destination-card" spacing="15">
                    <VBox styleClass="destination-image destination-paris"
                          prefHeight="200" alignment="BOTTOM_LEFT">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="Paris" styleClass="destination-name"/>
                    </VBox>
                    <VBox spacing="8">
                        <padding>
                            <Insets top="0" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="La ville lumière vous attend" styleClass="destination-desc"/>
                        <Label text="À partir de 850€" styleClass="destination-price"/>
                    </VBox>
                </VBox>

                <!-- Destination Card 2 -->
                <VBox styleClass="destination-card" spacing="15">
                    <VBox styleClass="destination-image destination-istanbul"
                          prefHeight="200" alignment="BOTTOM_LEFT">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="Istanbul" styleClass="destination-name"/>
                    </VBox>
                    <VBox spacing="8">
                        <padding>
                            <Insets top="0" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="Entre Orient et Occident" styleClass="destination-desc"/>
                        <Label text="À partir de 650€" styleClass="destination-price"/>
                    </VBox>
                </VBox>

                <!-- Destination Card 3 -->
                <VBox styleClass="destination-card" spacing="15">
                    <VBox styleClass="destination-image destination-dubai"
                          prefHeight="200" alignment="BOTTOM_LEFT">
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="Dubaï" styleClass="destination-name"/>
                    </VBox>
                    <VBox spacing="8">
                        <padding>
                            <Insets top="0" right="15" bottom="15" left="15"/>
                        </padding>
                        <Label text="Luxe et modernité" styleClass="destination-desc"/>
                        <Label text="À partir de 1200€" styleClass="destination-price"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>

        <!-- SERVICES -->
        <VBox styleClass="services-section" spacing="30">
            <padding>
                <Insets top="60" right="40" bottom="60" left="40"/>
            </padding>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Nos Services" styleClass="section-title-white"/>
                <Label text="Un accompagnement complet pour votre voyage"
                       styleClass="section-subtitle-white"/>
            </VBox>

            <HBox spacing="30" alignment="CENTER">
                <!-- Service 1 -->
                <VBox styleClass="service-card" alignment="CENTER" spacing="15">
                    <Label text="✈️" style="-fx-font-size: 48px;"/>
                    <Label text="Vols" styleClass="service-title"/>
                    <Label text="Réservation de vols aux meilleurs tarifs"
                           styleClass="service-desc" wrapText="true" alignment="CENTER"/>
                </VBox>

                <!-- Service 2 -->
                <VBox styleClass="service-card" alignment="CENTER" spacing="15">
                    <Label text="🏨" style="-fx-font-size: 48px;"/>
                    <Label text="Hébergement" styleClass="service-title"/>
                    <Label text="Hôtels sélectionnés pour votre confort"
                           styleClass="service-desc" wrapText="true" alignment="CENTER"/>
                </VBox>

                <!-- Service 3 -->
                <VBox styleClass="service-card" alignment="CENTER" spacing="15">
                    <Label text="🗺️" style="-fx-font-size: 48px;"/>
                    <Label text="Circuits" styleClass="service-title"/>
                    <Label text="Itinéraires personnalisés et guidés"
                           styleClass="service-desc" wrapText="true" alignment="CENTER"/>
                </VBox>

                <!-- Service 4 -->
                <VBox styleClass="service-card" alignment="CENTER" spacing="15">
                    <Label text="📋" style="-fx-font-size: 48px;"/>
                    <Label text="Visa" styleClass="service-title"/>
                    <Label text="Assistance pour vos formalités"
                           styleClass="service-desc" wrapText="true" alignment="CENTER"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- FOOTER -->
        <VBox styleClass="footer" spacing="20">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <HBox spacing="80" alignment="CENTER">
                <!-- Colonne 1 -->
                <VBox spacing="10">
                    <Label text="À propos" styleClass="footer-title"/>
                    <Label text="Notre histoire" styleClass="footer-link"/>
                    <Label text="Notre équipe" styleClass="footer-link"/>
                    <Label text="Nos valeurs" styleClass="footer-link"/>
                </VBox>

                <!-- Colonne 2 -->
                <VBox spacing="10">
                    <Label text="Services" styleClass="footer-title"/>
                    <Label text="Voyages sur mesure" styleClass="footer-link"/>
                    <Label text="Voyages organisés" styleClass="footer-link"/>
                    <Label text="Omra et Hajj" styleClass="footer-link"/>
                </VBox>

                <!-- Colonne 3 -->
                <VBox spacing="10">
                    <Label text="Contact" styleClass="footer-title"/>
                    <Label text="📧 contact@voyages-excellence.com" styleClass="footer-link"/>
                    <Label text="📞 +216 XX XXX XXX" styleClass="footer-link"/>
                    <Label text="📍 Tunis, Tunisie" styleClass="footer-link"/>
                </VBox>

                <!-- Colonne 4 -->
                <VBox spacing="10">
                    <Label text="Suivez-nous" styleClass="footer-title"/>
                    <HBox spacing="15">
                        <Label text="📘" style="-fx-font-size: 24px; -fx-cursor: hand;"/>
                        <Label text="📷" style="-fx-font-size: 24px; -fx-cursor: hand;"/>
                        <Label text="🐦" style="-fx-font-size: 24px; -fx-cursor: hand;"/>
                        <Label text="💼" style="-fx-font-size: 24px; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>

            <Separator/>

            <Label text="© 2024 Voyages Excellence. Tous droits réservés."
                   styleClass="footer-copyright" alignment="CENTER"/>
        </VBox>

    </VBox>

</ScrollPane>