<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="24" styleClass="animate-fade" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.client.BookingController">

    <!-- Progress Steps -->
    <HBox alignment="CENTER" spacing="32">
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step1Label" text="1" styleClass="step-circle, step-active"/>
            <Label text="Details" styleClass="step-text, step-active"/>
        </HBox>
        <Region prefWidth="40" styleClass="step-line"/>
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step2Label" text="2" styleClass="step-circle"/>
            <Label text="Payment" styleClass="step-text"/>
        </HBox>
        <Region prefWidth="40" styleClass="step-line"/>
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step3Label" text="3" styleClass="step-circle"/>
            <Label text="Confirm" styleClass="step-text"/>
        </HBox>
    </HBox>

    <!-- Back Button -->
    <Button fx:id="backButton" onAction="#handleBack" styleClass="outline-button" text="❮ Back"/>

    <!-- Content -->
    <HBox spacing="24" VBox.vgrow="ALWAYS">
        <!-- Main Form -->
        <VBox HBox.hgrow="ALWAYS" spacing="24">
            <!-- Forms Container -->
            <StackPane VBox.vgrow="ALWAYS">
                <!-- Guest Details Form -->
                <VBox fx:id="guestDetailsForm" styleClass="card">
                    <Label text="Booking Details" styleClass="card-title"/>

                    <GridPane hgap="16" vgap="16">
                        <VBox.margin>
                            <Insets top="16"/>
                        </VBox.margin>
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8">
                            <Label text="First Name" styleClass="field-label"/>
                            <TextField fx:id="firstNameField" promptText="John" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8">
                            <Label text="Last Name" styleClass="field-label"/>
                            <TextField fx:id="lastNameField" promptText="Doe" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="8" GridPane.columnSpan="2">
                            <Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="john.doe@email.com" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="8" GridPane.columnSpan="2">
                            <Label text="Phone Number" styleClass="field-label"/>
                            <TextField fx:id="phoneField" promptText="+1 (555) 000-0000" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="3" spacing="8" GridPane.columnSpan="2">
                            <Label text="Special Requests (Optional)" styleClass="field-label"/>
                            <TextArea fx:id="requestsArea" promptText="Any special requests or preferences..."
                                      styleClass="auth-input" prefRowCount="3"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Payment Form -->
                <VBox fx:id="paymentForm" styleClass="card" visible="false" managed="false">
                    <Label text="Payment Information" styleClass="card-title"/>

                    <VBox spacing="16">
                        <VBox.margin>
                            <Insets top="16"/>
                        </VBox.margin>

                        <VBox spacing="8">
                            <Label text="Card Number" styleClass="field-label"/>
                            <TextField fx:id="cardNumberField" promptText="1234 5678 9012 3456" styleClass="auth-input"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Cardholder Name" styleClass="field-label"/>
                            <TextField fx:id="cardNameField" promptText="John Doe" styleClass="auth-input"/>
                        </VBox>

                        <HBox spacing="16">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Expiry Date" styleClass="field-label"/>
                                <TextField fx:id="expiryField" promptText="MM/YY" styleClass="auth-input"/>
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="CVV" styleClass="field-label"/>
                                <TextField fx:id="cvvField" promptText="123" styleClass="auth-input"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <HBox styleClass="security-badge">
                        <VBox.margin>
                            <Insets top="16"/>
                        </VBox.margin>
                        <Label text="🔒 Secure 256-bit SSL encryption"/>
                    </HBox>
                </VBox>

                <!-- Confirmation View -->
                <VBox fx:id="confirmationView" styleClass="card" visible="false" managed="false" spacing="16" alignment="CENTER">
                    <padding>
                        <Insets bottom="32" left="32" right="32" top="32"/>
                    </padding>
                    <Label text="✅" style="-fx-font-size: 48; -fx-text-fill: #22C55E;"/>
                    <Label text="Ready to Book?" styleClass="card-title"/>
                    <Label text="Please review your details on the right before confirming."
                           textAlignment="CENTER" wrapText="true" textFill="#64748B"/>
                </VBox>
            </StackPane>

            <!-- Continue Button -->
            <Button fx:id="continueButton" onAction="#handleContinue" styleClass="primary-button" text="Continue" maxWidth="Infinity"/>
        </VBox>

        <!-- Summary Sidebar -->
        <VBox prefWidth="350" spacing="16" styleClass="card">
            <Label text="Booking Summary" styleClass="card-title"/>

            <VBox spacing="12">
                <VBox.margin>
                    <Insets top="16"/>
                </VBox.margin>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="hotelNameLabel" styleClass="hotel-name" text="Hotel Name"/>
                </HBox>

                <Label fx:id="roomTypeLabel" text="Room Type" styleClass="text-muted"/>

                <VBox spacing="8" styleClass="summary-section">
                    <HBox>
                        <Label text="Check-in" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="checkInLabel" text="Date"/>
                    </HBox>
                    <HBox>
                        <Label text="Check-out" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="checkOutLabel" text="Date"/>
                    </HBox>
                    <HBox>
                        <Label text="Guests" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="guestsLabel" text="1"/>
                    </HBox>
                    <HBox>
                        <Label text="Nights" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="nightsLabel" text="3"/>
                    </HBox>
                </VBox>

                <VBox spacing="8" styleClass="summary-section">
                    <HBox>
                        <Label text="Room Rate" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="roomRateLabel" text="\$0.00"/>
                    </HBox>
                    <HBox>
                        <Label text="Taxes &amp; Fees (12%)" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="taxesLabel" text="\$0.00"/>
                    </HBox>
                </VBox>

                <HBox styleClass="summary-total">
                    <Label text="Total" styleClass="total-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" text="\$0.00" styleClass="total-value"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
