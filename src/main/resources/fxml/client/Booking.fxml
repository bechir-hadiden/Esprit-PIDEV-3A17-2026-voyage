<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="24" styleClass="animate-fade" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.client.BookingController">

    <!-- Progress Steps -->
    <HBox alignment="CENTER" spacing="32">
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step1Label" text="1" styleClass="step-circle, step-active"/>
            <Label text="Details" styleClass="step-text, step-active"/>
        </HBox>
        <Region prefWidth="40" styleClass="step-line"/>
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step2Label" text="2" styleClass="step-circle"/>
            <Label text="Payment" styleClass="step-text"/>
        </HBox>
        <Region prefWidth="40" styleClass="step-line"/>
        <HBox alignment="CENTER" spacing="8">
            <Label fx:id="step3Label" text="3" styleClass="step-circle"/>
            <Label text="Confirm" styleClass="step-text"/>
        </HBox>
    </HBox>

    <!-- Back Button -->
    <Button fx:id="backButton" onAction="#handleBack" styleClass="outline-button" text="❮ Back"/>

    <!-- Content -->
    <HBox spacing="24" VBox.vgrow="ALWAYS">
        <!-- Main Form -->
        <VBox HBox.hgrow="ALWAYS" spacing="24">
            <!-- Forms Container -->
            <StackPane VBox.vgrow="ALWAYS">
                <!-- Guest Details Form -->
                <VBox fx:id="guestDetailsForm" styleClass="card">
                    <Label text="Booking Details" styleClass="card-title"/>

                    <GridPane hgap="16" vgap="16">
                        <VBox.margin>
                            <Insets top="16"/>
                        </VBox.margin>
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8">
                            <Label text="First Name" styleClass="field-label"/>
                            <TextField fx:id="firstNameField" promptText="John" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8">
                            <Label text="Last Name" styleClass="field-label"/>
                            <TextField fx:id="lastNameField" promptText="Doe" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="8" GridPane.columnSpan="2">
                            <Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="john.doe@email.com" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="8" GridPane.columnSpan="2">
                            <Label text="Phone Number" styleClass="field-label"/>
                            <TextField fx:id="phoneField" promptText="+1 (555) 000-0000" styleClass="auth-input"/>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="3" spacing="8" GridPane.columnSpan="2">
                            <Label text="Special Requests (Optional)" styleClass="field-label"/>
                            <TextArea fx:id="requestsArea" promptText="Any special requests or preferences..."
                                      styleClass="auth-input" prefRowCount="3"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Payment Form (Redesigned) -->
                <VBox fx:id="paymentForm" styleClass="card" visible="false" managed="false" spacing="24">
                    <Label text="Payment Method" styleClass="card-title"/>

                    <!-- User Balance Display -->
                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="ai-card">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="💰 My Wallet Balance" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                            <Label fx:id="walletBalanceLabel" text="0.00 DT" style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #22C55E;"/>
                        </VBox>
                        <Separator orientation="VERTICAL"/>
                        <VBox spacing="4">
                            <Label text="✨ Loyalty Points" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                            <Label fx:id="loyaltyPointsLabel" text="0 pts" style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #8b5cf6;"/>
                        </VBox>
                    </HBox>

                    <!-- Payment Options -->
                    <VBox spacing="12">
                        <Label text="Select your preferred method:" styleClass="field-label"/>
                        
                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            </columnConstraints>

                            <ToggleButton fx:id="stripeToggle" text="💳 Stripe (Card)" maxWidth="Infinity" styleClass="outline-button" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <toggleGroup><ToggleGroup fx:id="paymentGroup"/></toggleGroup>
                            </ToggleButton>
                            <ToggleButton fx:id="walletToggle" text="👛 Internal Wallet" maxWidth="Infinity" styleClass="outline-button" GridPane.columnIndex="1" GridPane.rowIndex="0" toggleGroup="$paymentGroup"/>
                            <ToggleButton fx:id="paypalToggle" text="🅿️ PayPal" maxWidth="Infinity" styleClass="outline-button" GridPane.columnIndex="0" GridPane.rowIndex="1" toggleGroup="$paymentGroup"/>
                            <ToggleButton fx:id="d17Toggle" text="📲 D17" maxWidth="Infinity" styleClass="outline-button" GridPane.columnIndex="1" GridPane.rowIndex="1" toggleGroup="$paymentGroup"/>
                        </GridPane>
                    </VBox>

                    <!-- Method Details -->
                    <StackPane fx:id="methodDetailsContainer">
                        <VBox fx:id="stripeDetails" spacing="12" alignment="CENTER" style="-fx-padding: 10;">
                            <Label text="You will be redirected to Stripe to pay securely by Card." styleClass="text-muted" textAlignment="CENTER" wrapText="true"/>
                            <HBox alignment="CENTER" spacing="8">
                                <Label text="Visa" styleClass="tag"/>
                                <Label text="Mastercard" styleClass="tag"/>
                                <Label text="Stripe" styleClass="tag-success"/>
                            </HBox>
                        </VBox>
                        <VBox fx:id="walletDetails" spacing="12" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                            <Label fx:id="walletStatusLabel" text="Pay instantly using your wallet balance." styleClass="text-muted" textAlignment="CENTER" wrapText="true"/>
                            <Label text="Get 5% immediate cashback in points!" style="-fx-text-fill: #22C55E; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox fx:id="paypalDetails" spacing="12" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                            <Label text="Login to your PayPal account to approve the payment." styleClass="text-muted" textAlignment="CENTER" wrapText="true"/>
                        </VBox>
                        <VBox fx:id="d17Details" spacing="12" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                            <Label text="Pay via D17 mobile app checkout." styleClass="text-muted" textAlignment="CENTER" wrapText="true"/>
                        </VBox>
                    </StackPane>

                    <HBox styleClass="security-badge" alignment="CENTER">
                        <Label text="🔒 Secure, encrypted transactions"/>
                    </HBox>
                </VBox>

                <!-- Confirmation View -->
                <VBox fx:id="confirmationView" styleClass="card" visible="false" managed="false" spacing="16" alignment="CENTER">
                    <padding>
                        <Insets bottom="32" left="32" right="32" top="32"/>
                    </padding>
                    <Label text="✅" style="-fx-font-size: 48; -fx-text-fill: #22C55E;"/>
                    <Label text="Ready to Book?" styleClass="card-title"/>
                    <Label text="Please review your details on the right before confirming."
                           textAlignment="CENTER" wrapText="true" textFill="#64748B"/>
                </VBox>
            </StackPane>

            <!-- Continue Button -->
            <Button fx:id="continueButton" onAction="#handleContinue" styleClass="primary-button" text="Continue" maxWidth="Infinity"/>
        </VBox>

        <!-- Summary Sidebar -->
        <VBox prefWidth="350" spacing="16" styleClass="card">
            <Label text="Booking Summary" styleClass="card-title"/>

            <VBox spacing="12">
                <VBox.margin>
                    <Insets top="16"/>
                </VBox.margin>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="hotelNameLabel" styleClass="hotel-name" text="Hotel Name"/>
                </HBox>

                <Label fx:id="roomTypeLabel" text="Room Type" styleClass="text-muted"/>

                <VBox spacing="8" styleClass="summary-section">
                    <HBox>
                        <Label text="Check-in" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="checkInLabel" text="Date"/>
                    </HBox>
                    <HBox>
                        <Label text="Check-out" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="checkOutLabel" text="Date"/>
                    </HBox>
                    <HBox>
                        <Label text="Guests" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="guestsLabel" text="1"/>
                    </HBox>
                    <HBox>
                        <Label text="Nights" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="nightsLabel" text="3"/>
                    </HBox>
                </VBox>

                <VBox spacing="8" styleClass="summary-section">
                    <HBox>
                        <Label text="Room Rate" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="roomRateLabel" text="\$0.00"/>
                    </HBox>
                    <HBox>
                        <Label text="Taxes &amp; Fees (12%)" styleClass="text-muted"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="taxesLabel" text="\$0.00"/>
                    </HBox>
                </VBox>

                <HBox styleClass="summary-total">
                    <Label text="Total" styleClass="total-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" text="\$0.00" styleClass="total-value"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
