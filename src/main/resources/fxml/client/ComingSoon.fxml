<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="30" stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo1.controller.client.ComingSoonController"
      style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #e2e8f0);">

    <padding>
        <Insets top="100" right="50" bottom="100" left="50"/>
    </padding>

    <!-- Icon -->
    <Label style="-fx-font-size: 100px; -fx-text-fill: #94a3b8;" text="🚧"/>

    <!-- Title -->
    <Label fx:id="titleLabel" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"
           text="Coming Soon"/>

    <!-- Message -->
    <VBox alignment="CENTER" spacing="15" maxWidth="600">
        <Label fx:id="messageLabel" style="-fx-font-size: 18px; -fx-text-fill: #64748b; -fx-wrap-text: true; -fx-text-alignment: center;"
               text="This feature is currently under development and will be available soon."/>
        <Label style="-fx-font-size: 16px; -fx-text-fill: #94a3b8; -fx-wrap-text: true; -fx-text-alignment: center;"
               text="We're working hard to bring you exciting new features. Stay tuned!"/>
    </VBox>

    <!-- Decorative Element -->
    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 30 0 0 0;">
        <Label style="-fx-font-size: 24px;" text="✨"/>
        <Label style="-fx-font-size: 24px;" text="🎯"/>
        <Label style="-fx-font-size: 24px;" text="🚀"/>
    </HBox>

</VBox>
