<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #F4F7FB;" stylesheets="@../../css/style2.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.controller.client.DetailOffreController">
    <children>
        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-background-color: white; -fx-background-radius: 20;">
            <children>
                <!-- Image Header -->
                <StackPane prefHeight="250.0">
                    <children>
                        <ImageView fx:id="imgDetail" fitHeight="250.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="false" />
                        <!-- Badge Remise sur l'image -->
                        <Label fx:id="lblRemiseBadge" text="-40%" style="-fx-background-color: #FF5A1F; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 18;" StackPane.alignment="TOP_RIGHT">
                            <StackPane.margin><Insets top="20" right="20"/></StackPane.margin>
                        </Label>
                    </children>
                </StackPane>

                <!-- Content Area -->
                <VBox spacing="12.0">
                    <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>
                    <children>
                        <Label fx:id="lblDestination" style="-fx-text-fill: #1A73E8; -fx-font-weight: bold; -fx-font-size: 16px;" text="📍 Destination" />

                        <Label fx:id="lblTitre" style="-fx-font-size: 22; -fx-font-weight: 900; -fx-text-fill: #05203C;" text="Titre de l'offre" wrapText="true" />

                        <!-- Dates Section -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <children>
                                <Label text="📅 Validité :" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" />
                                <Label fx:id="lblDates" text="Du 01/03 au 20/03" style="-fx-text-fill: #475569;" />
                            </children>
                        </HBox>

                        <Separator />

                        <Label text="À propos de cette offre" style="-fx-font-weight: bold; -fx-font-size: 14;" />

                        <ScrollPane fitToWidth="true" prefHeight="100.0" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                            <content>
                                <Label fx:id="lblDescription"
                                       text="Description détaillée..."
                                       wrapText="true"
                                       lineSpacing="4.0"
                                       alignment="TOP_LEFT"
                                       style="-fx-text-fill: #475569; -fx-font-size: 14px;" />
                            </content>
                        </ScrollPane>

                        <Separator />

                        <!-- Action Box (GÉNÉRATION + PDF + EMAIL) -->
                        <VBox spacing="15" alignment="CENTER" style="-fx-background-color: #F8FAFC; -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 15;">
                            <children>
                                <Label text="Obtenez votre coupon maintenant" style="-fx-font-weight: bold;" />
                                <Button fx:id="btnGenerer" onAction="#handleGenererPromo" styleClass="btn-add" text="Générer mon Code de réduction 🎁" prefWidth="320" />

                                <HBox spacing="8" alignment="CENTER">
                                    <children>
                                        <!-- Champ Code -->
                                        <TextField fx:id="txtCodeGenere" editable="false" prefHeight="40.0" prefWidth="160.0" promptText="Code généré" style="-fx-alignment: center; -fx-font-family: 'Monospaced'; -fx-font-weight: bold; -fx-font-size: 14;" />

                                        <!-- Bouton PDF (API 1) -->
                                        <Button fx:id="btnPDF" disable="true" onAction="#handleExportPDF" prefHeight="40.0" prefWidth="85.0" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 8;" text="PDF 📄" />

                                        <!-- Bouton EMAIL (API 2 - Nouveau) -->
                                        <Button fx:id="btnEmail" disable="true" onAction="#handleSendEmail" prefHeight="40.0" prefWidth="85.0" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-background-radius: 8;" text="Mail 📧" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="20">
                            <Button onAction="#handleFermer" styleClass="btn-delete" text="Fermer la fiche" prefWidth="150" />
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>