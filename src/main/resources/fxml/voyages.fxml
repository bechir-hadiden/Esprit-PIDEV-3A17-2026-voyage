<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo1.controller.VoyageController"
      spacing="20"
      stylesheets="@../css/style.css">

    <!-- En-tête -->
    <HBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
        <Label text="🌍 Nos Destinations Populaires"
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Barre de filtres -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: white;">
        <Label text="Filtrer par:"/>
        <ComboBox fx:id="cbFiltre" promptText="Toutes les destinations" prefWidth="200"/>

        <Button text="🔄 Actualiser les prix"
                onAction="#actualiserPrix"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 15;"/>

        <Button text="🔍 Recherche personnalisée"
                onAction="#ouvrirRecherchePersonnalisee"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 15;"/>
    </HBox>

    <!-- Grille de destinations -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="destinationsGrid"
                  hgap="20"
                  vgap="20"
                  alignment="CENTER"
                  style="-fx-background-color: #ecf0f1;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </FlowPane>
    </ScrollPane>

</VBox>