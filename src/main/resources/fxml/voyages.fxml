<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo1.controller.VoyageController"
      spacing="0"
      stylesheets="@../css/voyage.css, @../css/smarttrip_theme.css"
      style="-fx-background-color: #f5f0e8;">

    <!-- BARRE ACTIONS -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-padding: 15; -fx-background-color: white;
                 -fx-border-color: rgba(201,168,76,0.2); -fx-border-width: 0 0 1 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

        <Button text="➕ Ajouter un voyage"
                onAction="#handleAjouter"
                styleClass="btn-primary"
                style="-fx-padding: 10 20; -fx-background-radius: 12;"/>

        <Button text="🔄 Actualiser"
                onAction="#handleActualiser"
                styleClass="btn-outline-light"
                style="-fx-border-color: #0d1b2a; -fx-text-fill: #0d1b2a; -fx-padding: 10 20; -fx-border-radius: 12;"/>

        <Button text="🔍 Recherche vols"
                onAction="#ouvrirRecherchePersonnalisee"
                styleClass="btn-navy"
                style="-fx-padding: 10 20; -fx-background-radius: 12;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="tfRecherche"
                   promptText="🔍 Rechercher..."
                   onKeyReleased="#handleRecherche"
                   prefWidth="220"
                   styleClass="form-input-light"
                   style="-fx-padding: 8 12; -fx-background-radius: 12; -fx-border-radius: 12;"/>

        <ComboBox fx:id="cbFiltre"
                  promptText="Filtrer..."
                  prefWidth="160"
                  onAction="#appliquerFiltre"
                  styleClass="form-input-light"
                  style="-fx-background-radius: 12; -fx-border-radius: 12;"/>

        <Label fx:id="lblCount"
               style="-fx-font-family: 'Plus Jakarta Sans', sans-serif; -fx-font-size: 13px; -fx-text-fill: #7a8a99; -fx-font-weight: bold;"/>
    </HBox>

    <!-- LISTE VOYAGES -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f5f0e8; -fx-background: #f5f0e8; -fx-border-color: transparent;">
        <VBox fx:id="vboxVoyages" spacing="20"
              style="-fx-background-color: #f5f0e8; -fx-padding: 24;"/>
    </ScrollPane>

</VBox>