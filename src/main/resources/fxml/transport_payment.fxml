<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.TransportPaymentController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <stylesheets>
        <URL value="@../css/style.css" />
        <URL value="@../css/admin-styles.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 24 32 16 32; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <Button text="← Retour" onAction="#goBack"
                style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Paiement Transport" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
            <Label fx:id="reservationInfoLabel" text="Réservation #-"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
        </VBox>
        <Label fx:id="amountLabel" text="0.00 DT"
               style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #0ea5e9;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="20" style="-fx-padding: 32;" alignment="TOP_CENTER">

            <!-- Payment Method Card -->
            <VBox styleClass="admin-card" spacing="20" maxWidth="700" style="-fx-padding: 28;">
                <Label text="Payment Method" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>

                <!-- Wallet & Loyalty -->
                <HBox spacing="20" alignment="CENTER_LEFT"
                      style="-fx-background-color: #f0f9ff; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #bae6fd; -fx-border-radius: 12;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="💰 My Wallet Balance" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                        <Label fx:id="walletBalanceLabel" text="0.00 DT"
                               style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #22C55E;"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox spacing="4">
                        <Label text="✨ Loyalty Points" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                        <Label fx:id="loyaltyPointsLabel" text="0 pts"
                               style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #8b5cf6;"/>
                    </VBox>
                </HBox>

                <!-- Payment Options -->
                <VBox spacing="12">
                    <Label text="Select your preferred method:" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13;"/>
                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>
                        <ToggleButton fx:id="stripeToggle" text="💳 Stripe (Card)" maxWidth="Infinity"
                                      styleClass="outline-button" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <toggleGroup><ToggleGroup fx:id="paymentGroup"/></toggleGroup>
                        </ToggleButton>
                        <ToggleButton fx:id="walletToggle" text="👛 Internal Wallet" maxWidth="Infinity"
                                      styleClass="outline-button" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                      toggleGroup="$paymentGroup"/>
                        <ToggleButton fx:id="paypalToggle" text="🅿️ PayPal" maxWidth="Infinity"
                                      styleClass="outline-button" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                      toggleGroup="$paymentGroup"/>
                        <ToggleButton fx:id="d17Toggle" text="📲 D17" maxWidth="Infinity"
                                      styleClass="outline-button" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                      toggleGroup="$paymentGroup"/>
                    </GridPane>
                </VBox>

                <!-- Method Details -->
                <StackPane fx:id="methodDetailsContainer">
                    <VBox fx:id="stripeDetails" spacing="10" alignment="CENTER" style="-fx-padding: 10;">
                        <Label text="You will be redirected to Stripe to pay securely by Card."
                               style="-fx-text-fill: #64748b;" textAlignment="CENTER" wrapText="true"/>
                        <HBox alignment="CENTER" spacing="8">
                            <Label text="Visa" style="-fx-text-fill: #64748b; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-padding: 2 8; -fx-background-radius: 4;"/>
                            <Label text="Mastercard" style="-fx-text-fill: #64748b; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-padding: 2 8; -fx-background-radius: 4;"/>
                            <Label text="Stripe" style="-fx-text-fill: #22c55e; -fx-font-weight: bold; -fx-border-color: #86efac; -fx-border-radius: 4; -fx-padding: 2 8; -fx-background-radius: 4;"/>
                        </HBox>
                    </VBox>
                    <VBox fx:id="walletDetails" spacing="10" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                        <Label fx:id="walletStatusLabel" text="Pay instantly using your wallet balance."
                               style="-fx-text-fill: #64748b;" textAlignment="CENTER" wrapText="true"/>
                        <Label text="Get 5% immediate cashback in points!" style="-fx-text-fill: #22C55E; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox fx:id="paypalDetails" spacing="10" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                        <Label text="Login to your PayPal account to approve the payment."
                               style="-fx-text-fill: #64748b;" textAlignment="CENTER" wrapText="true"/>
                    </VBox>
                    <VBox fx:id="d17Details" spacing="10" alignment="CENTER" visible="false" style="-fx-padding: 10;">
                        <Label text="Pay via D17 mobile app checkout."
                               style="-fx-text-fill: #64748b;" textAlignment="CENTER" wrapText="true"/>
                    </VBox>
                </StackPane>

                <!-- Security Badge -->
                <HBox alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-padding: 10; -fx-background-radius: 8;">
                    <Label text="🔒 Secure, encrypted transactions" style="-fx-text-fill: #64748b;"/>
                </HBox>
            </VBox>

            <!-- Pay Button -->
            <Button fx:id="payButton" onAction="#handlePay" text="Pay with Stripe"
                    maxWidth="700"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 16 0; -fx-background-radius: 12; -fx-cursor: hand;"/>

        </VBox>
    </ScrollPane>

</VBox>
