<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.TransportListController"
            style="-fx-background-color: #f8fafc;">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header">
            <Button text="←" onAction="#goBack" styleClass="button-secondary" style="-fx-padding: 8 15; -fx-font-size: 16px;"/>
            <Label fx:id="titleLabel" text="Nos Transports" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 2 15; -fx-border-color: #e2e8f0; -fx-border-radius: 20;">
                <TextField fx:id="searchField" promptText="Rechercher une ville..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-pref-width: 200;"/>
                <Button onAction="#handleSearch" styleClass="button-icon" style="-fx-background-color: transparent;">
                    <graphic><Region styleClass="icon, icon-search" style="-fx-background-color: #64748b; -fx-pref-width: 16; -fx-pref-height: 16;"/></graphic>
                </Button>
                <Separator orientation="VERTICAL" prefHeight="20" style="-fx-padding: 0 5;"/>
                <Button onAction="#handleDetectLocation" styleClass="button-icon" style="-fx-background-color: transparent;">
                    <tooltip><Tooltip text="Détecter ma position"/></tooltip>
                    <graphic><Region styleClass="icon, icon-location" style="-fx-background-color: #3b82f6; -fx-pref-width: 16; -fx-pref-height: 16;"/></graphic>
                </Button>
            </HBox>
            <Button onAction="#rafraichir" styleClass="button-primary, button-icon" style="-fx-background-color: #2563eb;">
                <tooltip><Tooltip text="Rafraîchir la disponibilité"/></tooltip>
                <graphic><Region styleClass="icon, icon-refresh" style="-fx-background-color: white; -fx-pref-width: 20; -fx-pref-height: 20;"/></graphic>
            </Button>
        </HBox>
    </top>

    <!-- Transport Cards -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="40" style="-fx-padding: 60 40;" alignment="CENTER">
                <VBox alignment="CENTER" spacing="10">
                    <Label fx:id="mainTitleLabel" text="Véhicules Disponibles" styleClass="title-label"/>
                    <Label text="Choisissez le véhicule qui correspond à votre trajet" styleClass="subtitle-label"/>
                </VBox>
                <FlowPane fx:id="transportCardsPane" hgap="35" vgap="35" alignment="CENTER"/>
            </VBox>
        </ScrollPane>
    </center>


</BorderPane>
