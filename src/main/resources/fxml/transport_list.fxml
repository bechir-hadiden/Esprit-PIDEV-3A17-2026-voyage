<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controllers.TransportListController"
            style="-fx-background-color: #f8fafc;">

    <stylesheets>
        <URL value="@../css/style.css" />
        <URL value="@../css/admin-styles.css" />
    </stylesheets>

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 30 40 10 40;">
            <Button text="← Retour" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <Label fx:id="titleLabel" text="Nos Transports" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
            </VBox>
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 2 15; -fx-border-color: #e2e8f0; -fx-border-radius: 20;">
                <TextField fx:id="searchField" onAction="#handleSearch" promptText="Rechercher une ville..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-pref-width: 200;"/>
                <Button onAction="#handleSearch" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 5;">
                    <graphic><Label text="🔍" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/></graphic>
                </Button>
                <Separator orientation="VERTICAL" prefHeight="20" style="-fx-padding: 0 5;"/>
                <Button onAction="#handleDetectLocation" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 5;">
                    <tooltip><Tooltip text="Détecter ma position"/></tooltip>
                    <graphic><Label text="📍" style="-fx-font-size: 14px; -fx-text-fill: #3b82f6;"/></graphic>
                </Button>
            </HBox>
            <Button onAction="#rafraichir" styleClass="admin-button-secondary" text="🔄 Rafraîchir" style="-fx-padding: 8 16;">
                <tooltip><Tooltip text="Rafraîchir la disponibilité"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- Transport Cards -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="40" style="-fx-padding: 60 40;" alignment="CENTER">
                <VBox alignment="CENTER" spacing="10">
                    <Label fx:id="mainTitleLabel" text="Véhicules Disponibles" styleClass="title-label"/>
                    <Label text="Choisissez le véhicule qui correspond à votre trajet" styleClass="subtitle-label"/>
                </VBox>
                <FlowPane fx:id="transportCardsPane" hgap="35" vgap="35" alignment="CENTER"/>
            </VBox>
        </ScrollPane>
    </center>


</BorderPane>
