<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.LiveMapController"
      spacing="0"
      style="-fx-background-color: #f8fafc;">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header">
        <Button onAction="#handleBack" styleClass="button-secondary, button-icon">
            <graphic>
                <Region styleClass="icon, icon-back"/>
            </graphic>
        </Button>
        <Label text="Suivi Géographique des Véhicules" styleClass="header-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="Glissez un marqueur pour modifier la position..." style="-fx-text-fill: #64748b; -fx-font-style: italic;"/>
        <Button text="Rafraîchir" onAction="#handleRefresh" styleClass="button-primary"/>
    </HBox>

    <!-- Map Container -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 20;">
        <StackPane styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0; -fx-background-radius: 15; -fx-border-radius: 15; -fx-overflow: hidden;">
            <WebView fx:id="webView" prefHeight="600" prefWidth="800" />
        </StackPane>
    </VBox>

</VBox>
