<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.demo10.controller.MainMenuController"
            style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);">

    <!-- Centre : Menu principal -->
    <center>
        <VBox alignment="CENTER" spacing="30"
              style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 30;
                     -fx-padding: 40; -fx-max-width: 600; -fx-max-height: 800;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Logo / Icône -->
            <StackPane>
                <Circle radius="50" fill="linear-gradient(to bottom, #667eea, #764ba2)"/>
                <Label text="✈️" style="-fx-font-size: 48px; -fx-text-fill: white;"/>
            </StackPane>

            <!-- Titre -->
            <Label text="AGENCE DE VOYAGE"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
                <font>
                    <Font name="Arial" size="36"/>
                </font>
            </Label>

            <Label text="Bienvenue sur votre plateforme de gestion"
                   style="-fx-font-size: 16px; -fx-text-fill: #6c757d;"/>

            <Separator prefWidth="300"/>

            <!-- Menu des options -->
            <VBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 20 0;">

                <!-- Section 1 : Administration -->
                <Label text="👑 ESPACE ADMINISTRATION"
                       style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 14px; -fx-padding: 10 0 0 0;"/>

                <Button text="🔐 Gestion des avis" fx:id="btnAdmin"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-padding: 12 40; -fx-background-radius: 30; -fx-min-width: 350;"
                        onAction="#handleAdminMode"/>

                <!-- NOUVEAU BOUTON : Admin Réservations -->
                <Button text="🏨 Admin Réservations" fx:id="btnAdminReservations"
                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-padding: 12 40; -fx-background-radius: 30; -fx-min-width: 350;"
                        onAction="#handleAdminReservations"/>

                <Separator prefWidth="300"/>

                <!-- Section 2 : Espace Client -->
                <Label text="👤 ESPACE CLIENT"
                       style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 14px; -fx-padding: 10 0 0 0;"/>

                <Button text="📝 Gestion des avis" fx:id="btnClient"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-padding: 12 40; -fx-background-radius: 30; -fx-min-width: 350;"
                        onAction="#handleClientMode"/>

                <Button text="✈️ Nos voyages" fx:id="btnVoyages"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-padding: 12 40; -fx-background-radius: 30; -fx-min-width: 350;"
                        onAction="#handleVoyagesClient"/>

                <Separator prefWidth="300"/>

                <!-- Section 3 : Outils -->
                <Label text="📊 OUTILS"
                       style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 14px; -fx-padding: 10 0 0 0;"/>

                <Button text="📊 Statistiques globales" fx:id="btnStats"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-padding: 12 40; -fx-background-radius: 30; -fx-min-width: 350;"
                        onAction="#handleStatistiques"/>

            </VBox>

            <Separator prefWidth="300"/>

            <!-- Bouton Quitter -->
            <Button text="❌ Quitter l'application" fx:id="btnQuit"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-padding: 10 30; -fx-background-radius: 30; -fx-min-width: 250;"
                    onAction="#handleQuit"/>

            <!-- Informations de version -->
            <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                <Label text="Version 2.0.0 - Développé avec JavaFX"
                       style="-fx-text-fill: #6c757d; -fx-font-size: 11px;"/>
                <Label text="© 2026 Agence de Voyage - Tous droits réservés"
                       style="-fx-text-fill: #6c757d; -fx-font-size: 11px;"/>
            </VBox>

        </VBox>
    </center>

    <!-- Espacements pour centrer verticalement -->
    <top>
        <Region prefHeight="50"/>
    </top>
    <bottom>
        <Region prefHeight="50"/>
    </bottom>

</BorderPane>